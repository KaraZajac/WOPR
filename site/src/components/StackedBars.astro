---
// Stacked columns (sb/ns/os) with 2px surface gaps between segments, rounded
// data-end on the stack top only, legend + tooltips + table view. Bars stay
// ≤24px; the band's leftover is air.
import { column, scale, segment, ticks } from "../lib/scale.js";
import { num } from "../lib/format.js";

const {
  title,
  sub = "",
  rows = [],   // [[label, sb, ns, os], …]
  w = 520,
  h = 210,
  provisional = new Set(), // labels rendered at reduced opacity
} = Astro.props;

const KEYS = [
  { k: "sb", label: "state-based", col: 1 },
  { k: "ns", label: "non-state", col: 2 },
  { k: "os", label: "one-sided", col: 3 },
];
const PAD = { l: 52, r: 10, t: 10, b: 22 };
const totals = rows.map((r) => r[1] + r[2] + r[3]);
const tks = ticks(Math.max(...totals, 1));
const y = scale(0, tks[tks.length - 1], h - PAD.b, PAD.t);
const slotW = (w - PAD.l - PAD.r) / Math.max(rows.length, 1);
const barW = Math.min(24, Math.max(3, slotW - 3));
const GAP = 2;
const labelEvery = Math.max(1, Math.round(rows.length / 6));
---

<div class="card viz">
  <h3>{title}</h3>
  {sub && <p class="viz-sub">{sub}</p>}
  <div class="viz-scroll">
    <svg width={w} height={h} viewBox={`0 0 ${w} ${h}`} role="img" aria-label={title}>
      {tks.map((t) => (
        <>
          <line class="gridline" x1={PAD.l} x2={w - PAD.r} y1={y(t)} y2={y(t)} />
          <text class="tick-text" x={PAD.l - 6} y={y(t) + 3} text-anchor="end">{num(t)}</text>
        </>
      ))}
      {rows.map((r, i) => {
        const x0 = PAD.l + i * slotW + (slotW - barW) / 2;
        const total = r[1] + r[2] + r[3];
        let cursor = y(0);
        const segs = [];
        const present = KEYS.filter((kk) => r[kk.col] > 0);
        present.forEach((kk, j) => {
          const hPx = y(0) - y(r[kk.col]);
          const yTop = cursor - hPx;
          const isTop = j === present.length - 1;
          segs.push({
            kk,
            d: isTop ? column(x0, yTop, barW, cursor) : segment(x0, yTop + (j ? 0 : 0), barW, cursor),
            v: r[kk.col],
          });
          cursor = yTop - GAP;
        });
        return (
          <g class={`slot${provisional.has(r[0]) ? " provisional-mark" : ""}`}>
            {segs.map((s) => (
              <path class={`mark mark-${s.kk.k}`} d={s.d} />
            ))}
            <rect
              class="hit"
              x={PAD.l + i * slotW}
              y={PAD.t}
              width={slotW}
              height={h - PAD.t - PAD.b}
              tabindex="0"
              data-tip-value={`${num(total)} deaths`}
              data-tip-label={`${r[0]}${provisional.has(r[0]) ? " (provisional)" : ""} — sb ${num(r[1])} · ns ${num(r[2])} · os ${num(r[3])}`}
            />
            {i % labelEvery === 0 && (
              <text class="tick-text" x={PAD.l + i * slotW + slotW / 2} y={h - 6} text-anchor="middle">
                {String(r[0])}
              </text>
            )}
          </g>
        );
      })}
    </svg>
  </div>
  <div class="viz-legend">
    <span class="key"><span class="swatch sb"></span> state-based</span>
    <span class="key"><span class="swatch ns"></span> non-state</span>
    <span class="key"><span class="swatch os"></span> one-sided</span>
    {provisional.size > 0 && <span class="key"><span class="swatch provisional"></span> provisional (candidate months)</span>}
  </div>
  <details class="tableview">
    <summary>table view</summary>
    <table class="data">
      <thead><tr><th>period</th><th class="n">state-based</th><th class="n">non-state</th><th class="n">one-sided</th><th class="n">total</th></tr></thead>
      <tbody>
        {rows.map((r) => (
          <tr>
            <td>{String(r[0])}{provisional.has(r[0]) ? " *" : ""}</td>
            <td class="n">{num(r[1])}</td><td class="n">{num(r[2])}</td>
            <td class="n">{num(r[3])}</td><td class="n">{num(r[1] + r[2] + r[3])}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </details>
</div>
