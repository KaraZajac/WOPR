---
// The engine's prediction vs the latest challenger on a 0–1 track, with the
// resolved outcome as a vertical marker at 0 or 1.
import { pct } from "../lib/format.js";
const { prior = null, you = null, outcome = null } = Astro.props;
const x = (p) => `${(p * 100).toFixed(1)}%`;
---

<div class="dumbbell" role="img" aria-label={`engine ${pct(prior, 1)}, challenger ${pct(you, 1)}`}>
  <div class="track"></div>
  {prior != null && you != null && (
    <div
      class="link"
      style={`left:${x(Math.min(prior, you))};width:${x(Math.abs(you - prior))}`}
    ></div>
  )}
  {outcome != null && (
    <div class="outcome-line" style={`left:${outcome ? "100%" : "0%"}`} data-tip-value={outcome ? "resolved YES" : "resolved no"}></div>
  )}
  {prior != null && (
    <div class="pt prior" style={`left:${x(prior)}`} tabindex="0" data-tip-value={`engine ${pct(prior, 1)}`} data-tip-label="TOCSIN's prediction at ask-time"></div>
  )}
  {you != null && (
    <div class="pt you" style={`left:${x(you)}`} tabindex="0" data-tip-value={`challenger ${pct(you, 1)}`} data-tip-label="latest challenger forecast (another model, or an analyst)"></div>
  )}
</div>
